{
  "name": "tomate-launcher",
  "version": "1.0.0",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "postinstall": "node ./scripts/postinstall.js",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.renderer.json --composite false",
    "start": "electron-vite dev -w",
    "dev": "electron-vite dev -w",
    "build": "pnpm run typecheck && electron-vite build",
    "build:win": "pnpm run build && electron-builder --win --config",
    "build:mac": "pnpm run build && electron-builder --mac --config",
    "build:linux": "pnpm run build && electron-builder --linux --config",
    "build:wrapper": "mkdir -p extra-binaries && cd mc-wrapper && cargo build --release --bins && cp target/release/mc-wrapper ../extra-binaries"
  },
  "dependencies": {
    "@doublekekse/find-java": "github:Tomate0613/find-java",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@mdi/js": "^7.4.47",
    "@vueuse/core": "^14.3.0",
    "adm-zip": "^0.5.17",
    "ansi-colors": "^4.1.3",
    "axios": "^1.18.0",
    "axios-retry": "^4.5.0",
    "configparser": "^0.3.10",
    "fs-extra": "^11.3.5",
    "minecraftstatuspinger": "^1.2.2",
    "msmc": "^5.0.5",
    "openid-client": "^6.8.4",
    "pend": "^1.2.0",
    "prismarine-nbt": "^2.8.0",
    "skinview3d": "^3.4.2",
    "tomate-launcher-core": "github:Tomate0613/launcher-core",
    "tomate-loaders": "github:Tomate0613/tomate-loaders",
    "tomate-mods": "github:Tomate0613/tomate-mods",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@swc/core": "^1.15.41",
    "@types/adm-zip": "^0.5.8",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^26.0.0",
    "@types/yargs": "^17.0.35",
    "@vitejs/plugin-vue": "^6.0.7",
    "autoprefixer": "^10.5.0",
    "dotenv": "^17.4.2",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "6.0.0-beta.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vue-tsc": "^3.3.5"
  }
}
